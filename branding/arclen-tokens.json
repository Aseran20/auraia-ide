		"tokenColors": [
			{
				"scope": [
					"comment",
					"punctuation.definition.comment"
				],
				"settings": {
					"foreground": "$fg-3",
					"fontStyle": "italic"
				}
			},
			{
				"scope": [
					"string",
					"string.quoted",
					"punctuation.definition.string"
				],
				"settings": {
					"foreground": "$green-fg"
				}
			},
			{
				"scope": [
					"string.regexp",
					"constant.character.escape"
				],
				"settings": {
					"foreground": "$accent-fg"
				}
			},
			{
				"scope": [
					"constant.numeric",
					"constant.language",
					"keyword.other.unit",
					"support.constant"
				],
				"settings": {
					"foreground": "$yellow-fg"
				}
			},
			{
				"scope": [
					"constant.language.boolean",
					"constant.language.null",
					"constant.language.undefined"
				],
				"settings": {
					"foreground": "$yellow-fg"
				}
			},
			{
				"scope": [
					"keyword",
					"keyword.control",
					"storage",
					"storage.type",
					"storage.modifier"
				],
				"settings": {
					"foreground": "$accent-fg"
				}
			},
			{
				"scope": [
					"keyword.operator",
					"punctuation.separator",
					"punctuation.terminator",
					"meta.brace"
				],
				"settings": {
					"foreground": "$fg-2"
				}
			},
			{
				"scope": [
					"entity.name.function",
					"support.function",
					"meta.function-call entity.name.function"
				],
				"settings": {
					"foreground": "$blue-fg"
				}
			},
			{
				"scope": [
					"entity.name.type",
					"entity.name.class",
					"support.type",
					"support.class",
					"entity.other.inherited-class"
				],
				"settings": {
					"foreground": "$yellow-fg"
				}
			},
			{
				"scope": [
					"variable",
					"meta.definition.variable",
					"variable.other.readwrite"
				],
				"settings": {
					"foreground": "$fg-1"
				}
			},
			{
				"scope": [
					"variable.parameter",
					"variable.other.constant"
				],
				"settings": {
					"foreground": "$fg-1"
				}
			},
			{
				"scope": [
					"variable.language",
					"variable.language.this"
				],
				"settings": {
					"foreground": "$red",
					"fontStyle": "italic"
				}
			},
			{
				"scope": [
					"variable.other.property",
					"variable.other.object.property",
					"support.variable.property",
					"meta.object-literal.key"
				],
				"settings": {
					"foreground": "$fg-2"
				}
			},
			{
				"scope": [
					"entity.name.tag",
					"punctuation.definition.tag"
				],
				"settings": {
					"foreground": "$red-fg"
				}
			},
			{
				"scope": [
					"entity.other.attribute-name"
				],
				"settings": {
					"foreground": "$accent-fg",
					"fontStyle": "italic"
				}
			},
			{
				"scope": [
					"support.type.property-name.css",
					"support.type.property-name"
				],
				"settings": {
					"foreground": "$blue-fg"
				}
			},
			{
				"scope": [
					"entity.name.selector",
					"entity.other.attribute-name.class.css",
					"entity.other.attribute-name.id.css"
				],
				"settings": {
					"foreground": "$yellow-fg"
				}
			},
			{
				"scope": [
					"support.constant.property-value.css",
					"constant.numeric.css",
					"keyword.other.unit.css"
				],
				"settings": {
					"foreground": "$green-fg"
				}
			},
			{
				"scope": [
					"markup.heading",
					"markup.heading entity.name",
					"entity.name.section"
				],
				"settings": {
					"foreground": "$accent-fg",
					"fontStyle": "bold"
				}
			},
			{
				"scope": [
					"markup.bold",
					"punctuation.definition.bold"
				],
				"settings": {
					"foreground": "$fg-1",
					"fontStyle": "bold"
				}
			},
			{
				"scope": [
					"markup.italic",
					"punctuation.definition.italic"
				],
				"settings": {
					"foreground": "$fg-1",
					"fontStyle": "italic"
				}
			},
			{
				"scope": [
					"markup.inline.raw",
					"markup.fenced_code",
					"markup.raw.block"
				],
				"settings": {
					"foreground": "$green-fg"
				}
			},
			{
				"scope": [
					"markup.underline.link",
					"string.other.link",
					"constant.other.reference.link.markdown"
				],
				"settings": {
					"foreground": "$accent-fg"
				}
			},
			{
				"scope": [
					"markup.list punctuation.definition.list",
					"markup.list.numbered",
					"markup.list.unnumbered"
				],
				"settings": {
					"foreground": "$accent"
				}
			},
			{
				"scope": [
					"markup.quote"
				],
				"settings": {
					"foreground": "$fg-2",
					"fontStyle": "italic"
				}
			},
			{
				"scope": [
					"markup.inserted",
					"punctuation.definition.inserted"
				],
				"settings": {
					"foreground": "$green-fg"
				}
			},
			{
				"scope": [
					"markup.deleted",
					"punctuation.definition.deleted"
				],
				"settings": {
					"foreground": "$red-fg"
				}
			},
			{
				"scope": [
					"markup.changed",
					"punctuation.definition.changed"
				],
				"settings": {
					"foreground": "$yellow-fg"
				}
			},
			{
				"scope": [
					"support.type.property-name.json",
					"string.quoted.double.json punctuation.definition.string"
				],
				"settings": {
					"foreground": "$blue-fg"
				}
			},
			{
				"scope": [
					"meta.structure.dictionary.value.json string.quoted.double",
					"meta.structure.array.json string.quoted.double"
				],
				"settings": {
					"foreground": "$green-fg"
				}
			},
			{
				"scope": [
					"invalid",
					"invalid.illegal"
				],
				"settings": {
					"foreground": "$red-fg"
				}
			},
			{
				"scope": [
					"invalid.deprecated"
				],
				"settings": {
					"foreground": "$yellow"
				}
			},
			{
				"scope": [
					"token.info-token"
				],
				"settings": {
					"foreground": "$blue-fg"
				}
			},
			{
				"scope": [
					"token.warn-token"
				],
				"settings": {
					"foreground": "$yellow-fg"
				}
			},
			{
				"scope": [
					"token.error-token"
				],
				"settings": {
					"foreground": "$red-fg"
				}
			},
			{
				"scope": [
					"token.debug-token"
				],
				"settings": {
					"foreground": "$magenta-fg"
				}
			}
		],
		"semanticTokenColors": {
			"property": "$fg-2",
			"variable.readonly": "$fg-1",
			"parameter": "$fg-1",
			"function": "$blue-fg",
			"method": "$blue-fg",
			"class": "$yellow-fg",
			"interface": "$yellow-fg",
			"type": "$yellow-fg",
			"enum": "$yellow-fg",
			"enumMember": "$green-fg",
			"namespace": "$accent-fg",
			"keyword": "$accent-fg",
			"string": "$green-fg",
			"number": "$yellow-fg",
			"comment": "$fg-3",
			"*.declaration": {
				"fontStyle": ""
			}
		}
	},
