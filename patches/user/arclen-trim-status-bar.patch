@@ -607,7 +607,22 @@ class EditorStatus extends Disposable {
 		this.updateElement(this.metadataElement, props, 'status.editor.info', StatusbarAlignment.RIGHT, 100);
 	}
 
+	// Arclen: developer-oriented editor status items hidden from the footer for the M&A cockpit.
+	// The underlying state + commands (change language, encoding, EOL, indentation…) stay fully
+	// registered — only their status-bar surface is suppressed. Notifications bell + accessibility
+	// indicators (tab-focus / column-selection / insert mode) are kept.
+	private static readonly arclenHiddenStatusIds = new Set<string>([
+		'status.editor.mode',        // language
+		'status.editor.selection',   // line / column
+		'status.editor.indentation',
+		'status.editor.encoding',
+		'status.editor.eol',
+	]);
+
 	private updateElement(element: MutableDisposable<IStatusbarEntryAccessor>, props: IStatusbarEntry, id: string, alignment: StatusbarAlignment, priority: number) {
+		if (EditorStatus.arclenHiddenStatusIds.has(id)) {
+			return; // Arclen: suppressed from the footer
+		}
 		if (!element.value) {
 			element.value = this.statusbarService.addEntry(props, id, alignment, priority);
 		} else {
