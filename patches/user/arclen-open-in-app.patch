+// Arclen: open the given file resources in their OS-default application (.pptx -> PowerPoint,
+// .xlsx -> Excel, .pdf -> the default reader, …). Mirrors revealResourcesInOS but hands each file
+// to its OS-associated app instead of revealing it in the file manager. The file ENGINE is
+// untouched — this is purely a convenience so analysts skip the "Reveal then double-click" dance.
+export function openResourcesInOSApp(resources: URI[], nativeHostService: INativeHostService): void {
+	if (resources.length) {
+		sequence(resources.map(r => async () => {
+			const localUri = toLocalFileUri(r);
+			if (localUri) {
+				await nativeHostService.openPath(localUri.fsPath);
+			}
+		}));
+	}
+}
