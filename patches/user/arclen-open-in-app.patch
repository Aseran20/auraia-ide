+
+// ─── Arclen: "Open in App" — open a file in its OS-default application ──────────────────────────
+// (.pptx -> PowerPoint, .xlsx -> Excel, .pdf -> default reader). Saves M&A analysts the
+// "Reveal in File Explorer then double-click" round-trip. The file engine stays untouched.
+
+const OPEN_IN_OS_APP_COMMAND_ID = 'arclen.openInDefaultApp';
+const OPEN_IN_OS_APP_LABEL = nls.localize2('arclenOpenInApp', "Open in App");
+const OPEN_IN_OS_APP_WHEN_CONTEXT = ResourceContextKey.Scheme.isEqualTo(Schemas.file);
+
+CommandsRegistry.registerCommand(OPEN_IN_OS_APP_COMMAND_ID, (accessor: ServicesAccessor, resource: URI | object) => {
+	const resources = getMultiSelectedResources(resource, accessor.get(IListService), accessor.get(IEditorService), accessor.get(IEditorGroupsService), accessor.get(IExplorerService));
+	openResourcesInOSApp(resources, accessor.get(INativeHostService));
+});
+
+const openInOsAppCommand = {
+	id: OPEN_IN_OS_APP_COMMAND_ID,
+	title: OPEN_IN_OS_APP_LABEL.value
+};
+MenuRegistry.appendMenuItem(MenuId.ExplorerContext, {
+	group: 'navigation',
+	order: 8, // Arclen: top of the navigation group (above Open to the Side/Reveal) — deliverables-first
+	command: openInOsAppCommand,
+	when: OPEN_IN_OS_APP_WHEN_CONTEXT
+});
+MenuRegistry.appendMenuItem(MenuId.OpenEditorsContext, {
+	group: 'navigation',
+	order: 8, // Arclen: top of the navigation group
+	command: openInOsAppCommand,
+	when: OPEN_IN_OS_APP_WHEN_CONTEXT
+});
+appendToCommandPalette({
+	id: OPEN_IN_OS_APP_COMMAND_ID,
+	title: OPEN_IN_OS_APP_LABEL,
+	category: category
+}, OPEN_IN_OS_APP_WHEN_CONTEXT);
