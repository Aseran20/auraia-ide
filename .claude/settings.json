{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run.sh .claude/hooks/arclen-orient.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run.sh .claude/hooks/arclen-guard-destructive.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run.sh .claude/hooks/arclen-check-brand.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/run.sh .claude/hooks/arclen-track-edits.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
